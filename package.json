{
  "//": "中国大陆网络环境安装需设置 ELECTRON_MIRROR:  ELECTRON_MIRROR=\"https://npmmirror.com/mirrors/electron/\" pnpm install",
  "name": "claude-code-guide",
  "version": "1.0.0",
  "description": "claudeCode引导 - 一键安装 Claude Code",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc && node -e \"require('fs').cpSync('src/renderer','dist/renderer',{recursive:true})\" && electron .",
    "build": "node scripts/build.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0"
  }
}
